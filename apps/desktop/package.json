{
  "name": "miaoyi-chuhai-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "predev": "node scripts/startup-health-check.js",
    "dev": "concurrently \"vite --host 127.0.0.1 --port 5173 --clearScreen false\" \"cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 env -u ELECTRON_RUN_AS_NODE electron .\"",
    "predev:renderer": "kill-port 5173 5174 || true",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --clearScreen false",
    "dev:docker": "vite --host 0.0.0.0 --port 5174 --clearScreen false",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:logic": "vitest run",
    "test:auth": "vitest run src/api.test.ts src/authApi.test.ts src/hooks/useCloudAuthGate.test.tsx src/components/AppOverlays.authGate.test.tsx electron/authHelpers.test.js",
    "doctor:backend": "node scripts/startup-health-check.js",
    "test:electron:upload-smoke": "node scripts/electron-upload-smoke.js",
    "build": "vite build",
    "regress": "bash scripts/regression.sh",
    "dist": "npm run build && electron-builder -c electron-builder.yml",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "antd": "^5.14.0",
    "axios": "^1.6.8",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3",
    "electronmon": "^1.0.4",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "kill-port": "^2.0.1",
    "typescript": "^5.4.4",
    "vite": "^5.2.0",
    "vitest": "^4.0.18"
  }
}
