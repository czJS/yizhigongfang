FROM ollama/ollama:latest

ARG OLLAMA_VERSION=0.17.6

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates curl zstd; \
    rm -rf /var/lib/apt/lists/*; \
    curl -fsSL "https://github.com/ollama/ollama/releases/download/v${OLLAMA_VERSION}/ollama-linux-arm64.tar.zst" -o /tmp/ollama.tar.zst; \
    mkdir -p /tmp/ollama-extract; \
    path="$(tar --zstd -tf /tmp/ollama.tar.zst | awk '($0=="ollama" || $0=="./ollama" || $0 ~ /\/ollama$/){print $0; exit}')"; \
    path="${path#./}"; \
    test -n "$path"; \
    tar --zstd -xf /tmp/ollama.tar.zst -C /tmp/ollama-extract "$path"; \
    install -m 0755 "/tmp/ollama-extract/$path" /bin/ollama; \
    /bin/ollama --version

EXPOSE 11434

ENTRYPOINT ["/bin/ollama"]
CMD ["serve"]

